# Copy this file to .env and fill in your key.
# Get a free key at https://aistudio.google.com/apikey
# The key must start with AIzaSy — do NOT use AQ. keys.
GEMINI_API_KEY=your_api_key_here

# Optional: port (default 3001)
PORT=3001

# Optional: Gemini model (default gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Optional: request timeout in ms (default 120000)
# GEMINI_REQUEST_TIMEOUT_MS=120000
