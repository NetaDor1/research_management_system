# Copy this file to .env and fill in your key.
# Get a free key at https://aistudio.google.com/apikey
# Gemini API key from https://aistudio.google.com/apikey
# (Google may issue keys in different prefixes, e.g. AQ... or AIza...)
GEMINI_API_KEY=your_api_key_here

# Optional: port (default 3001)
PORT=3001

# Optional: Gemini model (default gemini-2.5-flash-lite)
# GEMINI_MODEL=gemini-2.5-flash-lite

# Optional: request timeout in ms (default 120000)
# GEMINI_REQUEST_TIMEOUT_MS=120000

# Firebase Admin — required to fully delete rejected users (Auth + Firestore)
# Download service account JSON from Firebase Console → Project settings → Service accounts
# FIREBASE_PROJECT_ID=research-management-syst-11bea
# FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
